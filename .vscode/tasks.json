{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jekyll: Serve (développement)",
      "type": "shell",
      "command": "bundle exec jekyll serve --livereload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Bundle: Install",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Lance le serveur Jekyll avec livereload sur http://localhost:4000",
      "isBackground": true,
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Jekyll: Build",
      "type": "shell",
      "command": "bundle exec jekyll build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Bundle: Install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Construit le site sans le servir"
    },
    {
      "label": "Jekyll: Clean",
      "type": "shell",
      "command": "bundle exec jekyll clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Bundle: Install",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Nettoie le dossier _site/"
    },
    {
      "label": "Bundle: Install",
      "type": "shell",
      "command": "bash -lc 'export BUNDLE_APP_CONFIG=\"$PWD/.bundle\"; export BUNDLE_PATH=\"$PWD/vendor/bundle\"; export BUNDLE_JOBS=\"1\"; bundle install --retry 3'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Installe les dépendances Ruby"
    },
    {
      "label": "🔍 Vérifier les liens internes (script maison)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["internal"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie les liens internes directement dans les fichiers Markdown (numéros de ligne corrects)"
    },
    {
      "label": "🔍 Vérifier les liens externes (script maison)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["external"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie les liens externes avec cache (numéros de ligne corrects)"
    },
    {
      "label": "🔍 Vérifier les liens (scripts maison)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["both"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie les liens internes et externes avec les scripts maison"
    },
    {
      "label": "🔍 Vérifier les liens (htmlproofer)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["htmlproofer"],
      "dependsOn": "Jekyll: Build",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie tous les liens avec htmlproofer (analyse _site, nécessite un build Jekyll)"
    },
    {
      "label": "🔍 Vérifier les liens (lychee)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["lychee"],
      "dependsOn": "Jekyll: Build",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie tous les liens avec lychee (analyse _site, nécessite un build Jekyll)"
    },
    {
      "label": "🔍 Vérifier les liens (toutes les méthodes)",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/check_links.sh",
      "args": ["all"],
      "dependsOn": "Jekyll: Build",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Vérifie les liens avec toutes les méthodes (scripts maison + htmlproofer + lychee)"
    },
    {
      "label": "🔐 Signer la whitelist apt-thirdparty",
      "type": "shell",
      "command": "${workspaceFolder}/.vscode/tasks/sign_apt_thirdparty_whitelist.sh",
      "args": [
        "${input:aptThirdpartySigningKey}"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Génère et signe apt-thirdparty/apps.tar et apt-thirdparty/apps.tar.asc depuis .apt-thirdparty/apps.d"
    }
  ],
  "inputs": [
    {
      "id": "aptThirdpartySigningKey",
      "type": "promptString",
      "description": "Identifiant de clé GPG (email ou key-id) pour signer la whitelist",
      "default": "you@example.com"
    }
  ]
}
